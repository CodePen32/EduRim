# ═══════════════════════════════════════════════════════
# EduRim Backend — Production Environment (Render)
# Copy this file to .env on Render via Environment Variables
# NEVER commit real values to Git
# ═══════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────
# Render injects PORT automatically — do not set manually
PORT=
APP_ENV=production

# ── Database (Railway MySQL) ─────────────────────────────
DB_HOST=your-railway-host.railway.app
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_railway_password
DB_NAME=railway

# ── Auth ─────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change_this_to_a_64_char_random_secret

# ── CORS ─────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://student.edurim.com,https://admin.edurim.com

# ── Storage (Cloudflare R2) ──────────────────────────────
STORAGE_DRIVER=r2
LOCAL_UPLOADS_DIR=uploads
LOCAL_PUBLIC_URL=http://localhost:8081/uploads
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=edurim-uploads
R2_PUBLIC_URL=https://files.edurim.com
