# ── Server ──────────────────────────────────────────────
# Render sets PORT automatically; SERVER_PORT is the local fallback
PORT=
SERVER_PORT=8081

# ── Database ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=edurim_db
DB_TLS=false

# Production (Railway):
# DB_HOST=containers-us-west-xxx.railway.app
# DB_PORT=6543
# DB_USER=root
# DB_PASSWORD=your_railway_password
# DB_NAME=railway

# ── Auth ─────────────────────────────────────────────────
# IMPORTANT: use a 32+ char random string in production
JWT_SECRET=your_super_secret_jwt_key_change_this

# ── CORS ─────────────────────────────────────────────────
# Leave empty in dev (allows all origins)
# Production: comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=https://student.edurim.com,https://admin.edurim.com

# ── Storage ──────────────────────────────────────────────
# "local" for development, "r2" for production (Cloudflare R2)
STORAGE_DRIVER=local

# Local storage settings (used when STORAGE_DRIVER=local)
LOCAL_UPLOADS_DIR=uploads
LOCAL_PUBLIC_URL=http://localhost:8081/uploads

# Cloudflare R2 settings (used when STORAGE_DRIVER=r2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=edurim-uploads
R2_PUBLIC_URL=https://files.edurim.com
